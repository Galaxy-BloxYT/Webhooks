-- [[ LÓGICA DE FARM COM MIRA NO CENTRO DA HANDLE ]]

local function serverHop()
    local success, Servers = pcall(function()
        return HttpService:JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Asc&limit=100"))
    end)
    if success then
        for _, s in ipairs(Servers.data) do
            if s.playing < s.maxPlayers and s.id ~= game.JobId then
                game:GetService("TeleportService"):TeleportToPlaceInstance(game.PlaceId, s.id)
                break
            end
        end
    end
end

local function runFarm()
    local destFolder = workspace:WaitForChild("Map"):WaitForChild("Destructibles")
    
    while task.wait(0.5) do
        local targets = {}
        for _, v in ipairs(destFolder:GetChildren()) do
            if v.Name:find("Pistol") then table.insert(targets, v) end
        end

        if #targets == 0 then serverHop() break end

        for _, target in ipairs(targets) do
            local char = player.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            if not root then continue end
            
            local handle = target:FindFirstChild("Handle") or target:FindFirstChildWhichIsA("BasePart")
            if handle then
                -- TELEPORTE: Fica a 2 studs de distância olhando para o CENTRO da Handle
                local targetPos = handle.Position
                root.CFrame = CFrame.lookAt(targetPos + Vector3.new(0, 2, 2), targetPos)
                
                local remote = char:WaitForChild("Events"):WaitForChild("MouseButton1")
                remote:FireServer(false)
                task.wait(0.1)
                remote:FireServer(true)
                task.wait(0.5)

                -- Verificação de Inventário
                local items = player.Backpack:GetChildren()
                for _, i in ipairs(char:GetChildren()) do if i:IsA("Tool") then table.insert(items, i) end end

                for _, item in ipairs(items) do
                    if item.Name == "Periastron" then
                        sendMyWebhook("🔥 PERIASTRON FOUND! (1%) 🔥")
                        return 
                    elseif item.Name:find("AK") then
                        sendMyWebhook("someone got an AK! (BAD)")
                        char.Humanoid.Health = 0 return
                    elseif item.Name:find("Pistol") then
                        sendMyWebhook("someone got a pistol! (BAD)")
                        char.Humanoid.Health = 0 return
                    end
                end
            end
        end
    end
end

