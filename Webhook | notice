local player = game:GetService("Players").LocalPlayer
local HttpService = game:GetService("HttpService")
local url = "https://rbxhook.cc/r/b80c4fe8c044764ca75da0078f913762"
local discord_pfp = "https://image2url.com/images/1765321843919-d6a101a5-e511-4c74-8cc4-2dc979ceddbc.png" 

local function sendMyWebhook(customTitle)
    local requestFunc = syn and syn.request or request or http_request or (http and http.request)
    if not requestFunc then return end
    
    local data = {
        username = "Galaxy's Hub | Gun Farm",
        avatar_url = discord_pfp,
        embeds = {{
            title = customTitle or "Item Found!",
            color = 3447003,
            thumbnail = { url = discord_pfp },
            fields = {
                { name = "User", value = player.Name, inline = true },
                { name = "Job ID", value = "```" .. game.JobId .. "```", inline = false }
            },
            timestamp = os.date("!%Y-%m-%dT%H:%M:%SZ")
        }}
    }
    pcall(function()
        requestFunc({Url = url, Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = HttpService:JSONEncode(data)})
    end)
end

-- [[ LÓGICA DE FARM ]]

local function serverHop()
    task.wait(2)
    local success, Servers = pcall(function()
        return HttpService:JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Asc&limit=100"))
    end)
    if success then
        for _, s in ipairs(Servers.data) do
            if s.playing < s.maxPlayers and s.id ~= game.JobId then
                game:GetService("TeleportService"):TeleportToPlaceInstance(game.PlaceId, s.id)
                break
            end
        end
    end
end

local function runFarm()
    local destFolder = workspace:WaitForChild("Destructibles", 10)
    if not destFolder then return end

    while task.wait(1) do
        local targets = {}
        for _, v in ipairs(destFolder:GetChildren()) do
            if v.Name == "Pistol" and v:IsA("Model") then table.insert(targets, v) end
        end

        if #targets == 0 then serverHop() break end

        for _, model in ipairs(targets) do
            local char = player.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            
            if root and model:FindFirstChild("Pistol") then
                local mesh = model.Pistol
                root.CFrame = CFrame.lookAt(mesh.Position + Vector3.new(0, 2, 2), mesh.Position)
                
                task.wait(0.5)
                
                local events = char and char:FindFirstChild("Events")
                local remote = events and events:FindFirstChild("MouseButton1")
                
                if remote then
                    pcall(function() remote:FireServer(true) end)
                    
                    for i = 1, 15 do
                        if not player.Character then break end 
                        task.wait(0.2)
                        
                        local items = player.Backpack:GetChildren()
                        for _, t in ipairs(player.Character:GetChildren()) do 
                            if t:IsA("Tool") then table.insert(items, t) end 
                        end

                        for _, item in ipairs(items) do
                            -- SÓ FOCO NA PERIASTRON
                            if item.Name == "Periastron" then
                                pcall(function() remote:FireServer(false) end)
                                sendMyWebhook("PERIASTRON! (1% btw)")
                                return -- Para o script completamente porque atingiu o objetivo
                            end
                        end
                    end
                    if remote then pcall(function() remote:FireServer(false) end) end
                end
            end
        end
    end
end

